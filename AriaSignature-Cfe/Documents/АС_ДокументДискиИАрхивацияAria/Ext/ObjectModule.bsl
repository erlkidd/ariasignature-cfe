Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если Не ЗначениеЗаполнено(Контрагент) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Компьютер) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	ДатаЗаписи = ПолучитьДатуЗаписиРегистра();
	
	Движения.АС_РегистрДискиAria.Записывать = Истина;
	НомерЗаписиДиски = 0;
	Для Каждого СтрокаДиска Из Диски Цикл
		НомерЗаписиДиски = НомерЗаписиДиски + 1;
		ЗаписьРегистра = Движения.АС_РегистрДискиAria.Добавить();
		ЗаписьРегистра.Контрагент = Контрагент;
		ЗаписьРегистра.Компьютер = Компьютер;
		ЗаписьРегистра.Дата = ДатаЗаписи;
		ЗаписьРегистра.Номер = Строка(НомерЗаписиДиски);
		ЗаписьРегистра.Диск = СтрокаДиска.Диск;
		ЗаписьРегистра.Здоровье = СтрокаДиска.Здоровье;
		ЗаписьРегистра.Объем = СтрокаДиска.Объем;
		ЗаписьРегистра.Свободно = СтрокаДиска.Свободно;
		ЗаписьРегистра.Занято = СтрокаДиска.Занято;
		ЗаписьРегистра.Температура = СтрокаДиска.Температура;
		ЗаписьРегистра.ДатаОбновления = СтрокаДиска.ДатаПоследнегоОбновленияДиски;
	КонецЦикла;
	
	Движения.АС_РегистрАрхивацииAria.Записывать = Истина;
	НомерЗаписиАрхивации = 0;
	Для Каждого СтрокаАрхивации Из Архивации Цикл
		НомерЗаписиАрхивации = НомерЗаписиАрхивации + 1;
		ЗаписьРегистра = Движения.АС_РегистрАрхивацииAria.Добавить();
		ЗаписьРегистра.Контрагент = Контрагент;
		ЗаписьРегистра.Компьютер = Компьютер;
		ЗаписьРегистра.Дата = ДатаЗаписи;
		ЗаписьРегистра.Номер = Строка(НомерЗаписиАрхивации);
		ЗаписьРегистра.Задача = СтрокаАрхивации.Задача;
		ЗаписьРегистра.Статус = СтрокаАрхивации.Статус;
		ЗаписьРегистра.ПутьКБазе = СтрокаАрхивации.ПутьКБазе;
		ЗаписьРегистра.ПутьКАрхиву = СтрокаАрхивации.ПутьКАрхиву;
		ЗаписьРегистра.ДатаВыполнения = СтрокаАрхивации.ДатаВыполненияЗадачи;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьДатуЗаписиРегистра()
	Если ЗначениеЗаполнено(Дата) Тогда
		Возврат Дата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаДокумента) Тогда
		Возврат ДатаДокумента;
	КонецЕсли;
	
	Возврат ТекущаяДатаСеанса();
КонецФункции

