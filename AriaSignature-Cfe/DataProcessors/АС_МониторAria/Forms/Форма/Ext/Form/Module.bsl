&НаКлиенте
Перем КэшMelezh;

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	КэшMelezh = Новый Соответствие;
	НастроитьВыборКомпьютера();
	
	Если Не ВыбраныКонтрагентИКомпьютер() Тогда
		ОчиститьДанныеМонитораНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	АктуализироватьДанныеНаКлиенте(Ложь);
	Сообщить("Данные были актуализированы");
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключение(Команда)
	АктуализироватьДанныеНаКлиенте(Истина);
	Если Объект.Статус = "Подключено" Тогда
		Сообщить("Подключение успешно установлено");
	Иначе
		Сообщить("Не удалось установить подключение. Проверьте работу службы на этом компьютере");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДокументыУчета(Команда)
	Попытка
		СсылкаДокумента = СоздатьДокументДиагностикиНаСервере();
		Сообщить("Диагностика записана и проведена: " + Строка(СсылкаДокумента));
	Исключение
		Сообщить("Не удалось записать диагностику: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Объект.Компьютер = Неопределено;
	НастроитьВыборКомпьютера();
	ОчиститьДанныеМонитораНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура КомпьютерПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.Компьютер) И Не КомпьютерАктивенНаСервере(Объект.Компьютер) Тогда
		Сообщить("Этот компьютер в данный момент не активен. Пометьте справочник на удаление или проверьте работу устройства.");
		Объект.Компьютер = Неопределено;
		ОчиститьДанныеМонитораНаКлиенте();
		Возврат;
	КонецЕсли;
	
	Если ВыбраныКонтрагентИКомпьютер() Тогда
		АктуализироватьДанныеНаКлиенте(Ложь);
	Иначе
		ОчиститьДанныеМонитораНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КомпьютерНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Сообщить("Сначала выберите контрагента.");
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;
	СтандартнаяОбработка = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКомпьютера(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	ДанныеВыбораПК = ИзвлечьДанныеКомпьютераИзРезультатаВыбора(ВыбранноеЗначение);
	Если ДанныеВыбораПК = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеВыбораПК.Активен Тогда
		Сообщить("Этот компьютер в данный момент не активен. Пометьте справочник на удаление или проверьте работу устройства.");
		Объект.Компьютер = Неопределено;
		ОчиститьДанныеМонитораНаКлиенте();
		Возврат;
	КонецЕсли;
	
	Объект.Компьютер = ДанныеВыбораПК.Ссылка;
	КомпьютерПриИзменении(Неопределено);
КонецПроцедуры

&НаКлиенте
Функция ИзвлечьДанныеКомпьютераИзРезультатаВыбора(РезультатВыбора)
	Если РезультатВыбора = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("Массив") Тогда
		Если РезультатВыбора.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		РезультатВыбора = РезультатВыбора[0];
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("ЭлементСпискаЗначений") Тогда
		РезультатВыбора = РезультатВыбора.Значение;
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("Структура") Тогда
		ЗначениеВыбора = Неопределено;
		Если РезультатВыбора.Свойство("ВыбранноеЗначение", ЗначениеВыбора) Тогда
			РезультатВыбора = ЗначениеВыбора;
		ИначеЕсли РезультатВыбора.Свойство("Значение", ЗначениеВыбора) Тогда
			РезультатВыбора = ЗначениеВыбора;
		ИначеЕсли РезультатВыбора.Свойство("Ссылка", ЗначениеВыбора) Тогда
			РезультатВыбора = ЗначениеВыбора;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("Ссылка", РезультатВыбора);
	СтруктураРезультата.Вставить("Активен", КомпьютерАктивенНаСервере(РезультатВыбора));
	СтруктураРезультата.Вставить("Представление", Строка(РезультатВыбора));
	Возврат СтруктураРезультата;
КонецФункции

&НаСервере
Функция ПолучитьКомпьютерыКонтрагентаНаСервере(Знач Контрагент)
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Компьютеры.Ссылка КАК Ссылка,
	|	Компьютеры.Наименование КАК Наименование,
	|	Компьютеры.Код КАК Код,
	|	Компьютеры.Активен КАК Активен
	|ИЗ
	|	Справочник.АС_КомпьютерыAria КАК Компьютеры
	|ГДЕ
	|	Компьютеры.КонтрагентПК = &Контрагент
	|УПОРЯДОЧИТЬ ПО
	|	Компьютеры.Наименование";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтруктураПК = Новый Структура;
		СтруктураПК.Вставить("Ссылка", Выборка.Ссылка);
		СтруктураПК.Вставить("Активен", Выборка.Активен);
		Представление = СформироватьПредставлениеКомпьютераНаСервере(Выборка.Наименование, Выборка.Код);
		Если Не Выборка.Активен Тогда
			Представление = Представление + " [неактивен]";
		КонецЕсли;
		СтруктураПК.Вставить("Представление", Представление);
		Результат.Добавить(СтруктураПК);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

&НаКлиенте
Функция ПолучитьКэшMelezh() Экспорт
	Возврат КэшMelezh;
КонецФункции

&НаКлиенте
Процедура АктуализироватьДанныеНаКлиенте(ТолькоПроверкаПодключения = Ложь)
	Если Не ВыбраныКонтрагентИКомпьютер() Тогда
		ОчиститьДанныеМонитораНаКлиенте();
		Возврат;
	КонецЕсли;
	
	КэшMelezh = АктуализироватьДанныеMelezhНаСервере(ТолькоПроверкаПодключения);
	ПрименитьЦветовыеИндикаторы();
КонецПроцедуры

&НаКлиенте
Функция ВыбраныКонтрагентИКомпьютер()
	Возврат ЗначениеЗаполнено(Объект.Контрагент) И ЗначениеЗаполнено(Объект.Компьютер);
КонецФункции

&НаКлиенте
Процедура НастроитьВыборКомпьютера()
	ЭлементКомпьютер = Элементы.Найти("Компьютер");
	Если ЭлементКомпьютер = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВыбора = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ЭлементКомпьютер.Доступность = Истина;
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("КонтрагентПК", Объект.Контрагент));
	Иначе
		ЭлементКомпьютер.Доступность = Ложь;
	КонецЕсли;
	
	ЭлементКомпьютер.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьДанныеМонитораНаКлиенте()
	Объект.Статус = "";
	Объект.Диски.Очистить();
	Объект.Архивации.Очистить();
	Объект.ОСистеме.Очистить();
	КэшMelezh = Новый Соответствие;
	СброситьЦветовыеИндикаторы();
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьЦветовыеИндикаторы()
	Зеленый = WebЦвета.Зеленый;
	Красный = WebЦвета.Красный;
	Стандартный = WebЦвета.Черный;
	
	ЭлементСтатуса = Элементы.Найти("Статус");
	Если ЭлементСтатуса <> Неопределено Тогда
		Если Объект.Статус = "Подключено" Тогда
			ЭлементСтатуса.ЦветТекста = Зеленый;
		ИначеЕсли ЗначениеЗаполнено(Объект.Статус) Тогда
			ЭлементСтатуса.ЦветТекста = Красный;
		Иначе
			ЭлементСтатуса.ЦветТекста = Стандартный;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СброситьЦветовыеИндикаторы()
	Стандартный = WebЦвета.Черный;
	УстановитьЦветЭлемента("Статус", Стандартный, Стандартный);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЦветЭлемента(ИмяЭлемента, ЦветЭлемента, ЦветПоУмолчанию)
	ЭлементФормы = Элементы.Найти(ИмяЭлемента);
	Если ЭлементФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЦветЭлемента = Неопределено Тогда
		ЭлементФормы.ЦветТекста = ЦветПоУмолчанию;
	Иначе
		ЭлементФормы.ЦветТекста = ЦветЭлемента;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция АктуализироватьДанныеMelezhНаСервере(Знач ТолькоПроверкаПодключения = Ложь)
	Результат = АС_ПодключениеКMelezh.ПолучитьДанныеMelezh(Объект.Контрагент, Объект.Компьютер, ТолькоПроверкаПодключения);
	Мета = Результат.Получить("meta");
	Если Мета = Неопределено Тогда
		Мета = Новый Соответствие;
	КонецЕсли;
	
	Объект.Статус = ЗначениеДляСтроковогоРеквизита(Мета.Получить("connectionStatus"));
	
	Если Не ТолькоПроверкаПодключения Тогда
		Если Мета.Получить("isReady") Тогда
			АС_ПодключениеКMelezh.ЗаполнитьОбъектДиагностики(Объект, Результат);
		Иначе
			АС_ПодключениеКMelezh.ОчиститьТабличныеЧасти(Объект);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция КомпьютерАктивенНаСервере(Знач Компьютер)
	СсылкаПК = НайтиСсылкуКомпьютераНаСервере(Компьютер);
	Если СсылкаПК = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Компьютеры.Активен КАК Активен
	|ИЗ
	|	Справочник.АС_КомпьютерыAria КАК Компьютеры
	|ГДЕ
	|	Компьютеры.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", СсылкаПК);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Активен;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

&НаСервере
Функция СформироватьПредставлениеКомпьютераНаСервере(Знач Наименование, Знач Код)
	Имя = СокрЛП(Строка(Наименование));
	КодСтрокой = СокрЛП(Строка(Код));
	Если ЗначениеЗаполнено(КодСтрокой) Тогда
		Возврат Имя + " (" + КодСтрокой + ")";
	КонецЕсли;
	Возврат Имя;
КонецФункции

&НаСервере
Функция НайтиСсылкуКомпьютераНаСервере(Знач Компьютер)
	Если Компьютер = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(Компьютер) = Тип("СправочникСсылка.АС_КомпьютерыAria") Тогда
		Возврат Компьютер;
	КонецЕсли;
	
	Поиск = СокрЛП(Строка(Компьютер));
	Если Не ЗначениеЗаполнено(Поиск) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Компьютеры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.АС_КомпьютерыAria КАК Компьютеры
	|ГДЕ
	|	Компьютеры.Наименование = &Поиск
	|	ИЛИ Компьютеры.Код = &Поиск";
	Запрос.УстановитьПараметр("Поиск", Поиск);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

&НаСервере
Функция СоздатьДокументДиагностикиНаСервере()
	Если Не ЗначениеЗаполнено(Объект.Контрагент) ИЛИ Не ЗначениеЗаполнено(Объект.Компьютер) Тогда
		ВызватьИсключение "Перед записью диагностики выберите контрагента и компьютер.";
	КонецЕсли;
	
	ДокументДиагностики = Документы.АС_ДокументДискиИАрхивацияAria.СоздатьДокумент();
	ДатаДокумента = ПолучитьДатуДокументаИзМонитора();
	ДокументДиагностики.Дата = ДатаДокумента;
	ДокументДиагностики.Контрагент = Объект.Контрагент;
	ДокументДиагностики.Компьютер = Объект.Компьютер;
	ДокументДиагностики.ДатаДокумента = ДатаДокумента;
	
	КопироватьДискиВДокумент(ДокументДиагностики);
	КопироватьАрхивацииВДокумент(ДокументДиагностики);
	КопироватьОСистемеВДокумент(ДокументДиагностики);
	
	ДокументДиагностики.Записать(РежимЗаписиДокумента.Проведение);
	Возврат ДокументДиагностики.Ссылка;
КонецФункции

&НаСервере
Процедура КопироватьДискиВДокумент(ДокументДиагностики)
	ДокументДиагностики.Диски.Очистить();
	Для Каждого СтрокаМонитора Из Объект.Диски Цикл
		СтрокаДокумента = ДокументДиагностики.Диски.Добавить();
		СтрокаДокумента.Диск = СтрокаМонитора.Диск;
		СтрокаДокумента.Здоровье = СтрокаМонитора.Здоровье;
		СтрокаДокумента.Объем = СтрокаМонитора.Объем;
		СтрокаДокумента.Свободно = СтрокаМонитора.Свободно;
		СтрокаДокумента.Занято = СтрокаМонитора.Занято;
		СтрокаДокумента.Температура = СтрокаМонитора.Температура;
		СтрокаДокумента.ДатаПоследнегоОбновленияДиски = СтрокаМонитора.ДатаПоследнегоОбновленияДиски;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура КопироватьАрхивацииВДокумент(ДокументДиагностики)
	ДокументДиагностики.Архивации.Очистить();
	Для Каждого СтрокаМонитора Из Объект.Архивации Цикл
		СтрокаДокумента = ДокументДиагностики.Архивации.Добавить();
		СтрокаДокумента.Задача = СтрокаМонитора.Задача;
		СтрокаДокумента.Статус = СтрокаМонитора.Статус;
		СтрокаДокумента.ПутьКБазе = СтрокаМонитора.ПутьКБазе;
		СтрокаДокумента.ПутьКАрхиву = СтрокаМонитора.ПутьКАрхиву;
		СтрокаДокумента.ДатаВыполненияЗадачи = СтрокаМонитора.ДатаВыполненияЗадачи;
		СтрокаДокумента.ДатаПоследнегоОбновленияАрхивации = СтрокаМонитора.ДатаПоследнегоОбновленияАрхивации;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура КопироватьОСистемеВДокумент(ДокументДиагностики)
	ДокументДиагностики.ОСистеме.Очистить();
	Для Каждого СтрокаМонитора Из Объект.ОСистеме Цикл
		СтрокаДокумента = ДокументДиагностики.ОСистеме.Добавить();
		СтрокаДокумента.HostName = СтрокаМонитора.HostName;
		СтрокаДокумента.IPАдреса = СтрокаМонитора.IPАдреса;
		СтрокаДокумента.ОперационнаяСистема = СтрокаМонитора.ОперационнаяСистема;
		СтрокаДокумента.Процессор = СтрокаМонитора.Процессор;
		СтрокаДокумента.Видеокарта = СтрокаМонитора.Видеокарта;
		СтрокаДокумента.ОЗУ = СтрокаМонитора.ОЗУ;
		СтрокаДокумента.ДатаПоследнегоОбновленияСистемы = СтрокаМонитора.ДатаПоследнегоОбновленияСистемы;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьДатуДокументаИзМонитора()
	СтрокаДаты = "";
	
	Если Объект.ОСистеме.Количество() > 0 Тогда
		СтрокаДаты = Объект.ОСистеме[0].ДатаПоследнегоОбновленияСистемы;
	ИначеЕсли Объект.Диски.Количество() > 0 Тогда
		СтрокаДаты = Объект.Диски[0].ДатаПоследнегоОбновленияДиски;
	ИначеЕсли Объект.Архивации.Количество() > 0 Тогда
		СтрокаДаты = Объект.Архивации[0].ДатаПоследнегоОбновленияАрхивации;
	Иначе
		СтрокаДаты = "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДаты) Тогда
		Попытка
			Возврат Дата(СтрокаДаты);
		Исключение
			СтрокаДаты = "";
		КонецПопытки;
	КонецЕсли;
	
	Возврат ТекущаяДатаСеанса();
КонецФункции

&НаСервере
Функция ЗначениеДляСтроковогоРеквизита(Значение)
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат СокрЛП(Строка(Значение));
КонецФункции

