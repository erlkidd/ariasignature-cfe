//+ BAS 23.05.2026 : Получение данных Melezh в соответствия
&НаКлиенте
Перем КэшMelezh;

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	КэшMelezh = ПолучитьДанныеMelezhНаСервере();
КонецПроцедуры

&НаКлиенте
Функция ПолучитьКэшMelezh() Экспорт
	Возврат КэшMelezh;
КонецФункции

&НаСервере
Функция ПолучитьДанныеMelezhНаСервере()
	БазовыйURL = "http://127.0.0.1:7788";
	Результат = Новый Соответствие;
	
	Результат.Вставить("meta", Новый Соответствие);
	Результат["meta"].Вставить("baseUrl", БазовыйURL);
	Результат["meta"].Вставить("loadedAt", ТекущаяДатаСеанса());
	
	Результат.Вставить("ping", ВыполнитьGETMelezh(БазовыйURL + "/aria_ping"));
	
	Если Не Результат["ping"]["ok"] Тогда
		Результат["meta"].Вставить("isReady", Ложь);
		Возврат Результат;
	КонецЕсли;
	
	Результат.Вставить("status", ВыполнитьGETMelezh(БазовыйURL + "/aria_get_status"));
	Результат.Вставить("system", ВыполнитьGETMelezh(БазовыйURL + "/aria_get_system"));
	Результат.Вставить("disks", ВыполнитьGETMelezh(БазовыйURL + "/aria_get_disks"));
	Результат.Вставить("backups", ВыполнитьGETMelezh(БазовыйURL + "/aria_get_backups"));
	Результат.Вставить("backupsLogs", ВыполнитьGETMelezh(БазовыйURL + "/aria_get_backups_logs"));
	
	Результат["meta"].Вставить("isReady", Истина);
	Возврат Результат;
КонецФункции

&НаСервере
Функция ВыполнитьGETMelezh(URL)
	ОтветЗапроса = Новый Соответствие;
	ОтветЗапроса.Вставить("ok", Ложь);
	ОтветЗапроса.Вставить("url", URL);
	ОтветЗапроса.Вставить("data", Неопределено);
	ОтветЗапроса.Вставить("error", "");
	
	Попытка
		ОтветЗапроса["data"] = OPI_ЗапросыHTTP.Get(URL);
		ОтветЗапроса["ok"] = Истина;
	Исключение
		ОтветЗапроса["error"] = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат ОтветЗапроса;
КонецФункции
//- BAS 23.05.2026 : Получение данных Melezh в соответствия
