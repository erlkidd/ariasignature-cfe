/// Удаляет декорацию с формы (надпись, картинку, разделитель)
// Параметры:
//  Форма  - ФормаКлиентскогоПриложения - изменяемая форма
//
//  ИмяДекорации  - Строка - имя удаляемой декорации
//
Процедура УдалитьДекорациюФормы(Форма, ИмяДекорации) Экспорт
	Декорация = Форма.Элементы.Найти(ИмяДекорации);
	Если Декорация <> Неопределено И ТипЗнч(Декорация) = Тип("ДекорацияФормы") Тогда
		Форма.Элементы.Удалить(Декорация);
	КонецЕсли;
КонецПроцедуры

/// Удаляет группу страниц с формы
// Параметры:
//  Форма  - ФормаКлиентскогоПриложения - изменяемая форма
//
//  ИмяГруппыСтраниц  - Строка - имя удаляемой группы страниц
//
//  УдалитьСтраницы  - Булево - если Истина, удаляет все страницы группы. По умолчанию Истина
//
Процедура УдалитьГруппуСтраницФормы(Форма, ИмяГруппыСтраниц, УдалитьСтраницы = Истина) Экспорт
	ГруппаСтраниц = Форма.Элементы.Найти(ИмяГруппыСтраниц);
	Если ГруппаСтраниц = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если УдалитьСтраницы И ГруппаСтраниц.Элементы.Количество() > 0 Тогда
		МассивИменЭлементов = Новый Массив;
		Для Каждого ДочернийЭлемент Из ГруппаСтраниц.Элементы Цикл
			МассивИменЭлементов.Добавить(ДочернийЭлемент.Имя);
		КонецЦикла;
		УдалитьЭлементыФормы(Форма, МассивИменЭлементов);
	КонецЕсли;
	Форма.Элементы.Удалить(ГруппаСтраниц);
КонецПроцедуры

