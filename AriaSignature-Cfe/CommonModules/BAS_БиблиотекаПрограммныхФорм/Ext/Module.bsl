/// Добавляет табличный документ на форму:
// Параметры:
//  Форма  - ФормаКлиентскогоПриложения - изменяемая форма
//
//  ИмяДокумента  - Строка - имя нового табличного документа
//
//  ИмяГруппы  - Строка - имя родительского элемента. По умолчанию корень формы
//
//  ПутьКДанным  - Строка - путь к данным (реквизит типа ТабличныйДокумент). По умолчанию Объект.<ИмяДокумента>
//
//  Видимость  - Булево - видимость документа. По умолчанию Истина
//
//  ТолькоПросмотр  - Булево - только просмотр. По умолчанию Ложь
//
Процедура ДобавитьТабличныйДокументНаФорму(Форма, ИмяДокумента, ИмяГруппы = "", ПутьКДанным = "",
	Видимость = Истина, ТолькоПросмотр = Ложь) Экспорт
	Если ЗначениеЗаполнено(ИмяГруппы) Тогда
		ЭлементРодитель = Форма.Элементы[ИмяГруппы];
	Иначе
		ЭлементРодитель = Форма;
	КонецЕсли;
	ТабДок = Форма.Элементы.Добавить(ИмяДокумента, Тип("ПолеФормы"), ЭлементРодитель);
	ТабДок.Вид = ВидПоляФормы.ТабличныйДокумент;
	Если ЗначениеЗаполнено(ПутьКДанным) Тогда
		ТабДок.ПутьКДанным = ПутьКДанным;
	Иначе
		ТабДок.ПутьКДанным = "Объект." + ИмяДокумента;
	КонецЕсли;
	ТабДок.Видимость = Видимость;
	ТабДок.ТолькоПросмотр = ТолькоПросмотр;
КонецПроцедуры

