&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если ЭтоНовый() Тогда
		Активен = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписью(Отказ)
	НезаполненныеПоля = Новый Массив;
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		НезаполненныеПоля.Добавить("Наименование");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИмяПК) Тогда
		НезаполненныеПоля.Добавить("ИмяПК");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КонтрагентПК) Тогда
		НезаполненныеПоля.Добавить("КонтрагентПК");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(IPУстройства) Тогда
		НезаполненныеПоля.Добавить("IPУстройства");
	КонецЕсли;
	
	Если НезаполненныеПоля.Количество() > 0 Тогда
		Отказ = Истина;
		Сообщить("Не заполнены обязательные реквизиты: " + СтрСоединить(НезаполненныеПоля, ", "));
	КонецЕсли;
КонецПроцедуры
